# EthioLoadAI Example Environment

# Laravel
APP_NAME=EthioLoadAI
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=ethioloadai
DB_USERNAME=postgres
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# JWT / Sanctum
JWT_SECRET=
SANCTUM_STATEFUL_DOMAINS=localhost

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

# AI Engine
AI_ENGINE_URL=http://localhost:8000

# Payment Integrations
TELEBIRR_API_KEY=
CBE_BIRR_API_KEY=
CHAPA_API_KEY=

# Map Services
MAPBOX_TOKEN=
OPENSTREETMAP_URL=https://www.openstreetmap.org
