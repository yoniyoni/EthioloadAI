# Local development settings for the React admin panel (freight-link).
# These are NOT committed — gitignore covers *.local files.
#
# PORT: Vite dev server port (must not conflict with api-server)
PORT=5173

# BASE_PATH: URL prefix for assets
BASE_PATH=/

# VITE_API_TARGET: All /api requests are proxied here (Laravel backend)
VITE_API_TARGET=http://backend.test
